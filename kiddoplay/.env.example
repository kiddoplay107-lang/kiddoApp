# Google Drive API Configuration (Server-Side Only)
# DO NOT prefix these with VITE_ to keep them hidden from the frontend
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# For Vercel Deployment:
# Add these variables in the Vercel Dashboard under Settings -> Environment Variables
# GOOGLE_SERVICE_ACCOUNT_JSON: The full JSON content of your Service Account Key
# GOOGLE_DRIVE_ROOT_FOLDER_ID: The ID of the root folder containing your video folders

# Environment
NODE_ENV=development
PORT=3000
